# Copy this file to .env and fill in real values. .env is gitignored —
# never commit real secrets.

# --- Indexing (Postgres) ---
# Falls back to a local Postgres at localhost:5432 if unset (see main.go's
# defaultPostgresDSN). docker-compose.yml overrides this to point at the
# bundled postgres service instead.
BEP_POSTGRES_DSN=

# --- Blob storage ---
# If BEP_S3_BUCKET is set, blobs go to S3 instead of local disk (data/events).
BEP_S3_BUCKET=
BEP_S3_REGION=
BEP_S3_ENDPOINT=
# When BEP_S3_BUCKET is set, reads are cached on local disk (data/blobcache)
# by default — see src/blobstore/diskcache. No effect in local-disk mode
# (it's already local). Defaults to a 1 GiB cap if unset.
BEP_BLOB_CACHE_MAX_BYTES=
BEP_BLOB_CACHE_DISABLE=

# --- Remote cache (bytestream:// log/output-file fetching) ---
BEP_REMOTE_CACHE_INSECURE=
BEP_REMOTE_CACHE_HEADER=
# Max bytes fetched into memory per file (log file or build output artifact)
# in the Targets tab. Defaults to 20MB if unset — fine for log files, but
# output artifacts (compiled binaries, etc.) can be larger.
BEP_REMOTE_CACHE_MAX_BLOB_BYTES=

# --- Web UI SSO (OIDC) ---
# Leave BEP_OIDC_ISSUER_URL/BEP_OIDC_CLIENT_ID unset to serve the web UI
# unauthenticated (e.g. local dev). If set, all of the following except
# BEP_OIDC_SCOPES are required.
BEP_OIDC_ISSUER_URL=
BEP_OIDC_CLIENT_ID=
BEP_OIDC_CLIENT_SECRET=
BEP_OIDC_REDIRECT_URL=
# Space-separated; defaults to "openid profile email" if unset.
BEP_OIDC_SCOPES=
# Must be at least 16 bytes; rotating it invalidates all sessions.
# Generate with: openssl rand -base64 32
BEP_SESSION_SECRET=
# Set to "true" only for local HTTP (non-TLS) testing. Never set in production.
BEP_INSECURE_COOKIES=
# If "true", startup fails when OIDC isn't configured, instead of silently
# serving the web UI unauthenticated. Set this in production so a missing
# BEP_OIDC_* config can't accidentally expose the UI with no auth.
BEP_REQUIRE_AUTH=
